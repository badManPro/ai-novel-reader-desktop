# CosyVoice local wrapper (Baymax Mac mini)
COSYVOICE_PORT=9880
COSYVOICE_HOST=127.0.0.1
COSYVOICE_PYTHON=/Users/baymax/AI/offline-tts/CosyVoice/.venv/bin/python
# CosyVoice 官方仓库的可用 HTTP 入口在 runtime/python/fastapi/server.py
COSYVOICE_ENTRY=runtime/python/fastapi/server.py
# 这里填仓库根目录；真正模型路径通过 EXTRA_ARGS 里的 --model_dir 传入
COSYVOICE_MODEL_DIR=/Users/baymax/AI/offline-tts/CosyVoice
COSYVOICE_EXTRA_ARGS='--model_dir /Users/baymax/AI/offline-tts/CosyVoice/pretrained_models/CosyVoice-300M-SFT'
