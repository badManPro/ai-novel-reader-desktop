# GPT-SoVITS local wrapper example
GPTSOVITS_PORT=9881
GPTSOVITS_HOST=127.0.0.1
GPTSOVITS_PYTHON=/absolute/path/to/GPT-SoVITS/.venv/bin/python
GPTSOVITS_ENTRY=api_v2.py
GPTSOVITS_MODEL_DIR=/absolute/path/to/GPT-SoVITS
GPTSOVITS_REF_AUDIO_PATH=
GPTSOVITS_PROMPT_TEXT=
# 若默认 GPT_SoVITS/configs/tts_infer.yaml 不适配，可在此补 -c /absolute/path/to/tts_infer.yaml
GPTSOVITS_EXTRA_ARGS=
