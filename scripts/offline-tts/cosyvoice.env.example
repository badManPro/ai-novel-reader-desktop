# CosyVoice local wrapper example (SFT mainline)
COSYVOICE_PORT=9880
COSYVOICE_HOST=127.0.0.1
COSYVOICE_PYTHON=/absolute/path/to/CosyVoice/.venv/bin/python
# 推荐使用官方 FastAPI 入口
COSYVOICE_ENTRY=runtime/python/fastapi/server.py
# 这里填写 CosyVoice 仓库根目录
COSYVOICE_MODEL_DIR=/absolute/path/to/CosyVoice
# 主路线建议切到 CosyVoice-300M-SFT，桌面端默认走 /inference_sft + spk_id
COSYVOICE_EXTRA_ARGS='--model_dir /absolute/path/to/CosyVoice/pretrained_models/CosyVoice-300M-SFT'
# 可选：桌面端默认 speaker-id，不填则由 UI voiceId 决定
COSYVOICE_DEFAULT_SPK_ID=中文女
